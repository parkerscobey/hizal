# Server
PORT=8080
ENV=development
# Comma-separated list or '*' (for local-only use)
CORS_ALLOW_ORIGINS=http://localhost:5173

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgres://user:password@localhost:5434/winnow?sslmode=disable

# App URLs
APP_BASE_URL=http://localhost:5173

# Email
EMAIL_FROM=Winnow Local <noreply@winnow.local>
SMTP_HOST=localhost
SMTP_PORT=1025

# OpenAI
OPENAI_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_SUCCESS_URL=http://localhost:5173/workspace/:orgId?upgraded=true
STRIPE_CANCEL_URL=http://localhost:5173/workspace/:orgId
